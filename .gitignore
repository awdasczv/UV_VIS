# ---------------------------------------------------------------
#  로컬 툴체인 (대용량 바이너리, 버전관리 대상 아님)
# ---------------------------------------------------------------
tools/
.mamba/
.venv/

# ---------------------------------------------------------------
#  계산 중간 산출물 (재현 가능, 용량이 큼)
# ---------------------------------------------------------------
# Psi4 scratch (DF 메트릭 파일 하나가 45 MB 씩 나온다)
molecules/*/calculations/_scratch/
molecules/*/calculations/**/scratch/
*.180
*.npy
psi.*
dfh.pmetric.*

# PCMSolver 가 작업 디렉터리에 흘리는 파일
cavity.npz
cavity.off*
PEDRA.OUT*
timer.dat

# --- calculations/ 는 화이트리스트 방식으로 관리한다 ---
#
# 왜 블랙리스트가 아닌가:
#   ORCA 는 계산 1건마다 .gbw(5.7MB x2), .cis(2.9MB), .densities(2.9MB) 같은
#   바이너리와 .diisao.tmp.0(40MB), .bas0, .soscfv.tmp.0 같은 임시파일을 쏟아낸다.
#   확장자를 하나씩 막는 방식으로는 계속 새는 것이 생긴다.
#   (실제로 '*.tmp' 패턴이 '.tmp.0' 을 못 걸러 40 MB 가 추적될 뻔했다)
#   그래서 전부 무시하고 정말 필요한 것만 되살린다.
#
# 되살리는 것: 입력(.inp) / 사람이 읽는 전체 로그(.out) / 파싱 결과(.json) / 구조(.xyz)
# 이 넷만 있으면 계산을 그대로 재현하고 검증할 수 있다.
# (2026-07-23 분자별 네임스페이스 molecules/<name>/ 도입에 맞춰 경로 재조정)
molecules/*/calculations/**
!molecules/*/calculations/**/
!molecules/*/calculations/**/*.inp
!molecules/*/calculations/**/*.out
!molecules/*/calculations/**/*.json
!molecules/*/calculations/**/*.xyz
!molecules/*/calculations/**/*.csv

# 구조 최적화가 남기는 중복 xyz 는 제외한다.
#   opt_trj.xyz : 최적화 경로의 모든 중간 구조 (수십 KB, 재현 가능)
#   opt.xyz     : ORCA 가 쓴 최종 구조. 우리가 optimized.xyz 로 따로 저장하므로 중복
# 최종 구조는 optimized.xyz 하나만 추적한다.
molecules/*/calculations/**/opt_trj.xyz
molecules/*/calculations/**/opt.xyz

# 컨포머 탐색의 원시 xtb 작업 디렉터리 (200 구조 x 3 토토머 = 파일 5000개 이상).
molecules/*/conformers/*/xtb/
molecules/*/conformers/*/crest_run/

# 개별 컨포머 xyz 는 추적하지 않는다.
# 같은 좌표가 molecules/<name>/conformers/<종>/conformers.xyz 안에 전부 들어 있어 중복이다.
# 필요하면 scripts/02d_extract_conformers.py 로 언제든 복원한다.
molecules/*/conformers/*/*_c[0-9][0-9][0-9].xyz
xtbopt.log
xtbrestart
xtbtopo.mol
wbo
charges
.xtboptok

# ---------------------------------------------------------------
#  파이썬
# ---------------------------------------------------------------
__pycache__/
*.pyc

# ---------------------------------------------------------------
#  OS
# ---------------------------------------------------------------
Thumbs.db
desktop.ini
